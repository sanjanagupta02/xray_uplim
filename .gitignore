# Large calibration files — must be copied manually from CALDB/CCF.
# NuSTAR: copy nu[A/B]2dpsfen*_*.fits from $CALDB/data/nustar/fpm/bcf/psf/
# XMM:    copy XRT[1-3]_XPSF_*.CCF from your SAS_CCFPATH directory
xray_uplim/data/nustar/
xray_uplim/data/xmm/
# Bundled Swift XRT PSF ships with the repo, no install needed.
!xray_uplim/data/swift/psf/psfconst_xrt.fits

